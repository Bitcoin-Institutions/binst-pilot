# Citrea Testnet deployment
CITREA_TESTNET_RPC_URL=https://rpc.testnet.citrea.xyz
CITREA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Bitcoin Core RPC (used by inscribe-binst.ts)
BTC_RPC_USER=testnet4rpc
BTC_RPC_PASS=YOUR_BITCOIN_RPC_PASSWORD_HERE
BTC_RPC_URL=http://127.0.0.1:48332

# Citrea Mainnet (when ready)
CITREA_MAINNET_RPC_URL=https://rpc.citrea.xyz
